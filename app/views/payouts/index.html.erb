<%= render(SectionComponent.new(title: 'My payouts')) do %>
  <div class="flex flex-col divide-y divide-slate-300">
    <% if @payouts.any? %>
      <%= render partial: 'table', locals: { payouts: @payouts } %>
    <% else %>
      <p class="text-slate-500 mb-6">
        You don't have any payouts yet.
      </p>
    <% end %>
  <% end %>
